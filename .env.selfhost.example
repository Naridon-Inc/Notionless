# Notionless self-host config. Copy to `.env`, edit, then:
#   docker compose -f docker-compose.selfhost.yml up -d
#
# The ONLY thing most people change is NL_DOMAIN (+ NL_TLS_EMAIL).

# ---------------------------------------------------------------------------
# Your public hostname. Point a DNS A record at this box, set it here, and Caddy
# fetches + auto-renews a Let's Encrypt HTTPS cert for it. No cert files, no
# certbot, nothing else to do.
#
#   NL_DOMAIN=docs.yourcompany.com
#
# Leave it as `:80` to run locally over plain HTTP (open http://localhost).
NL_DOMAIN=:80

# Email for the Let's Encrypt account (cert-expiry notices). Recommended once you
# set a real NL_DOMAIN. Ignored for the `:80` local case.
NL_TLS_EMAIL=

# ---------------------------------------------------------------------------
# Optional knobs — sensible defaults, most people leave these blank.

# Comma-separated extra web origins allowed to call the relay API. The web app's
# own origin is always allowed, so you usually need nothing here.
NL_ALLOWED_ORIGINS=

# Always-on encrypted sync (your "private cloud"). On by default: the relay keeps
# each note's CIPHERTEXT in a Docker volume so notes are available 24/7 even when
# every laptop is closed — the box can never read them. To run PURE peer-to-peer
# (stores nothing; notes sync only while ≥1 teammate is online), blank BOTH:
#   NL_PERSIST_DIR=          (relay stops persisting)
#   NL_CLOUD_SYNC_URL=       (clients stop mirroring to the box)
NL_PERSIST_DIR=/data
NL_CLOUD_SYNC_URL=/yjs

# Where the in-app "Download the desktop app" buttons point. Defaults to the
# official GitHub release; set this if you ship your own fork's build.
NL_DOWNLOAD_URL=

# Optional accounts layer (hybrid identity). Set to 1 to put an email/password
# sign-in in front of this web instance, on top of the default zero-account
# identity. Leave blank for the pure zero-account experience. Notes stay E2EE
# either way — an account only gates access, it can never read your content.
# The FIRST account created becomes the admin. See docs/SELF_HOSTING.md.
NL_ACCOUNTS=
# Who may sign up: "open" (anyone, good for a trusted company instance) or
# "closed" (only the first/admin account self-serves; others are admin-added).
NL_ACCOUNTS_SIGNUP=open
# Set 1 to also reject UNauthenticated sync (members-only instance). Leave blank
# unless you want to hard-lock the relay to signed-in users.
NL_ACCOUNTS_STRICT=
# Fixed secret so login sessions survive a relay restart. `openssl rand -hex 32`.
NL_ACCOUNTS_SECRET=

# Token to read the landing-page analytics dashboard (/stats.html). Only matters
# if you also serve the marketing page from this box. `openssl rand -hex 24`.
NL_ANALYTICS_TOKEN=
