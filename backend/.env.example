# Notionless signaling relay — stateless, stores nothing.
# (No database, no auth secrets, no billing.)

# Server Port
PORT=9008

# Environment
NODE_ENV=development

# CORS — comma-separated list of allowed web origins for your deployment.
# e.g. ALLOWED_ORIGINS=https://notes.example.com
ALLOWED_ORIGINS=

# OPTIONAL: always-on cloud sync.
# Leave BLANK to keep the relay stateless (the default — it stores nothing).
# Set it to a folder and the relay keeps each note's ENCRYPTED state in a file
# there, so your notes stay available even when everyone's app is closed. The
# server still never sees your password, keys, or readable text. See
# docs/SELF_HOSTED_SYNC.md.
# YJS_PERSIST_DIR=/data

# ----------------------------------------------------------------------------
# OPTIONAL: first-party marketing-site analytics (the landing page only).
# Privacy-respecting: cookieless, no raw IP stored, DNT honored, aggregate-only.
# This NEVER touches notes/keys/identity — see docs/ANALYTICS.md + analytics.js.
#
# Token required to read the /api/stats dashboard (stats.html). If unset, only
# localhost can read. Generate one: `openssl rand -hex 24`.
ANALYTICS_TOKEN=
# Where the append-only event store lives (default: backend/.analytics).
# ANALYTICS_DIR=/data/analytics
# Optional fixed secret for the daily visitor-hash salt (keeps unique counts
# stable across restarts). Defaults to ANALYTICS_TOKEN, else a per-boot random.
# ANALYTICS_SALT=
# Set true to disable collection entirely (endpoints return 404).
# ANALYTICS_DISABLE=false
